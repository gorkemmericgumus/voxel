{
  "name": "voxel",
  "version": "1.0.0",
  "description": "Voxel - Native desktop app",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.voxelworld.game",
    "productName": "Voxel",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "main.cjs",
      "src/**/*"
    ],
    "mac": {
      "category": "public.app-category.games",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  }
}
